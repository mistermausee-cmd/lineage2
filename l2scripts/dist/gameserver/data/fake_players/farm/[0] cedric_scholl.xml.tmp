	</zone>
	<on_obtain_max_level>
		<wait delay="" min_delay="1000" max_delay="2000" chance=""/>	<!--Ждем-->
		<random_action chance="">	<!--Идем в город-->
			<ordinary_actions chance="">	<!--Идем в бакалейную лавку-->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
			</ordinary_actions>
			<ordinary_actions>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
				<move_to_point x="" y="" z="" range="" min_range="" max_range="" chance=""/>	<!---->
			</ordinary_actions>
			<use_item id="" chance=""/>	<!--Используем SoE-->
		</random_action>
		<wait delay="" min_delay="10000" max_delay="20000" chance=""/>	<!--Ждем-->
		<add_item id="" count="" min_count="" max_count="" chance=""/>	<!---->
		<add_item id="" count="" min_count="" max_count="" chance=""/>	<!---->
		<add_item id="" count="" min_count="" max_count="" chance=""/>	<!---->
		<add_item id="" count="" min_count="" max_count="" chance=""/>	<!---->
		<teleport_to_point x="" y="" z="" chance=""/>	<!---->
	</on_obtain_max_level>
	<go_to_town farm_time="" min_farm_time="" max_farm_time="" chance="">
	</go_to_town>
</farm>